{
  "name": "datamoat",
  "version": "0.1.8",
  "description": "Automatically backs up Claude, Codex, and OpenClaw conversations",
  "license": "BUSL-1.1",
  "bin": {
    "datamoat": "./dist/cli.js"
  },
  "main": "./dist/electron/main.js",
  "scripts": {
    "build": "tsc && cp src/ui/index.html dist/ui/index.html && mkdir -p dist/electron/assets && cp src/electron/assets/*.png dist/electron/assets/ && node scripts/build-helper.js && node scripts/build-electron-app.js",
    "dev": "ts-node src/cli.ts",
    "dev:electron": "npm run build && electron dist/electron/main.js",
    "daemon": "ts-node src/daemon.ts",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "bip39": "^3.1.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "electron-updater": "^6.8.3",
    "express": "^4.18.3",
    "keytar": "^7.9.0",
    "open": "^10.1.0",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@electron/packager": "^18.4.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "electron": "^36.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
